# Database — Neon PostgreSQL
# Format: postgresql://user:pass@ep-xxx.neon.tech/leadsense_db?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/leadsense_db?sslmode=require

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-xxxx
# Model yang digunakan (default: claude-sonnet-4-5)
# Pilihan: claude-opus-4-5, claude-sonnet-4-5, claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-sonnet-4-5

# Auth — string random minimal 32 karakter
# Generate: openssl rand -base64 32
NUXT_SESSION_PASSWORD=your-super-secret-session-password-min-32-chars
