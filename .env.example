# Database — Neon PostgreSQL
# Format: postgresql://user:pass@ep-xxx.neon.tech/leadsense_db?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/leadsense_db?sslmode=require

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-xxxx
# Model yang digunakan (default: claude-sonnet-4-5)
# Pilihan: claude-opus-4-5, claude-sonnet-4-5, claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-sonnet-4-5

# Auth — string random minimal 32 karakter
# Generate: openssl rand -base64 32
NUXT_SESSION_PASSWORD=your-super-secret-session-password-min-32-chars

# Email notifications — Resend (https://resend.com)
# Optional: if not set, email notifications are disabled
RESEND_API_KEY=re_xxxx
RESEND_FROM=LeadSense AI <notifications@yourdomain.com>
RESEND_ALERT_TO=sales@yourdomain.com

# App URL (used in email links)
APP_URL=https://yourdomain.com

# Data mode: "true" = pakai mock data lokal (hotels.json), "false" = pakai real API
# Default: true (aman untuk development, ubah ke false saat API sudah siap)
USE_MOCK_DATA=true
# Base URL external API — wajib diisi saat USE_MOCK_DATA=false
# Contoh: https://api.tiket.com/v1 atau https://api.yourdomain.com
API_BASE_URL=https://api.yourdomain.com

# Search MS auth token (x-tkey header, dari config SearchMs:TKey)
API_TKEY=019b0b91-a036-78f3-a9de-368e92ae44ed
